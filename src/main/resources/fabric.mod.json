	"authors": [
		"Pigeon"
	],
	"contact": {
		"homepage": "https://fabricmc.net/",
		"sources": "https://github.com/FabricMC/fabric-example-mod"
	},
	"license": "CC0-1.0",
	"icon": "assets/grimoire/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"grimoire.modid.Grimoire"
		],
		"client": [
			"grimoire.modid.GrimoireModClient"
		],
		"cardinal-components": [
			"grimoire.modid.ModComponents"
		]
	},
	"custom": {
