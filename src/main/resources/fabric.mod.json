{
	"schemaVersion": 1,
	"id": "grimoire",
	"version": "${version}",
	"name": "QuestTome",
	"description": "QuestTome is a fantasy questing/bounty mod for getting those harder to farm resources, built for custom mod pack makers and servers in mind!",
	"authors": [
		"SensitivePigeon"
	],
	"contributors": [
		"Matija"],

	"contact": {
		"homepage": "https://github.com/sensitivepigeon/QuestTome",
		"sources": "https://github.com/sensitivepigeon/QuestTome"
	},
	"license": "CC-BY-4.0",
	"icon": "assets/grimoire/book.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"grimoire.modid.Grimoire"
		],
		"client": [
			"grimoire.modid.client.GrimoireModClient"
		],
		"cardinal-components": [
			"grimoire.modid.data.ModComponents"
		]
	},
	"custom": {
		"cardinal-components": [
			"grimoire:quest_progress"
		]
	},
	"mixins": [
		"grimoire.mixins.json"
	],
	"depends": {
		"fabricloader": ">=0.18.4",
		"minecraft": "~1.20.1",
		"java": ">=17",
		"fabric-api": "*"
	}
}